# PostgreSQL 連線字串，Drizzle client 與 drizzle-kit 都會讀取
# 格式：postgres://<使用者>:<密碼>@<主機>:<埠>/<資料庫名稱>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/todos

# Express 監聽埠（選用，預設 3000）
PORT=3000

# 前端 CORS 白名單（選用）：逗號分隔，可多組；留空或不設則允許所有來源
# 例：CORS_ORIGINS=https://app.example.com,http://localhost:5173
CORS_ORIGINS=
